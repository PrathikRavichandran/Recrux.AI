# Recrux.AI Backend env template

# GEMINI_API_KEY — Required for the LangGraph agents.
# Get one free at https://aistudio.google.com/app/apikey
# In production, set this via your platform's secrets UI (HF Spaces secrets,
# Render env vars, etc.) — NEVER commit a populated .env file.
GEMINI_API_KEY=

# ALLOWED_ORIGINS — comma-separated list of origins permitted by CORS.
# Local dev: http://localhost:3000,http://localhost:5173
# Production: paste your deployed frontend URL (e.g. https://recrux-ai.vercel.app)
# DO NOT use "*" in production with allow_credentials=true.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# PORT — HTTP port the server binds to.
# Local: 8000. On Hugging Face Spaces this must be 7860.
PORT=8000
